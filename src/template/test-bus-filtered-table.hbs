{{!-- 
  TEST: MessageBus Filtered Table (CAML Token Consumer)
  ======================================================
  Tests: {{filter.*}} token resolution in CAML, guard pattern, subscription onReceive:"merge"
  
  Setup:
  - List: Any list with a text/choice column you want to filter on
  - Property pane → Dynamic Data → Subscribe Topics:
      Topic: "filterCategory"   Context Key: "filter"   On Receive: Merge   Enabled: ✓
  - CAML Filter (in property pane):
      <Eq><FieldRef Name='Category'/><Value Type='Text'>{{filter.Title}}</Value></Eq>
      (Replace 'Category' with whatever column name matches the filter publisher's list)
  - Place test-bus-filter-publisher on the same page
  
  What to verify:
  ✓ Before selection: placeholder shown, NO SharePoint query fired (guard skips it)
  ✓ After filter click: CAML token resolves, filtered rows display
  ✓ Clear resets to placeholder
  ✓ Active filter banner shows the resolved filter value
--}}

<style>
  .filtered-{{wpId}} {
    font-family: var(--body-font, 'Segoe UI', sans-serif);
    padding: 16px;
  }
  .filtered-header-{{wpId}} {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid #d83b01;
  }
  .filtered-title-{{wpId}} { font-size: 18px; font-weight: 600; color: #d83b01; margin: 0; }
  .filtered-badge-{{wpId}} {
    font-size: 11px; background: #d83b01; color: #fff; padding: 2px 8px;
    border-radius: 12px; text-transform: uppercase;
  }
  .filtered-active-{{wpId}} {
    background: #fff4ce; border: 1px solid #ffb900; border-radius: 4px;
    padding: 8px 12px; margin-bottom: 12px; font-size: 13px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .filtered-table-{{wpId}} { width: 100%; border-collapse: collapse; }
  .filtered-table-{{wpId}} th {
    text-align: left; padding: 8px 12px; background: #fdf6f0;
    border-bottom: 2px solid #e1dfdd; font-size: 13px; color: #605e5c;
  }
  .filtered-table-{{wpId}} td { padding: 8px 12px; border-bottom: 1px solid #edebe9; font-size: 14px; }
  .filtered-placeholder-{{wpId}} {
    text-align: center; padding: 40px 20px; color: #a19f9d;
    border: 2px dashed #e1dfdd; border-radius: 8px;
  }
  .filtered-count-{{wpId}} { font-size: 12px; color: #605e5c; margin-top: 8px; }
</style>

<div class="filtered-{{wpId}}">
  <div class="filtered-header-{{wpId}}">
    <h3 class="filtered-title-{{wpId}}">Filtered Results</h3>
    <span class="filtered-badge-{{wpId}}">SUB ← filterCategory</span>
  </div>

  {{#if filter.Title}}
    <div class="filtered-active-{{wpId}}">
      <span>🔍 Filtering by: <strong>{{filter.Title}}</strong></span>
      <span>ID: {{filter.ID}}</span>
    </div>

    {{#if items.rows.length}}
    <table class="filtered-table-{{wpId}}">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Created</th>
          <th>Author</th>
        </tr>
      </thead>
      <tbody>
        {{#each items.rows}}
        <tr>
          <td>{{ID}}</td>
          <td>{{Title}}</td>
          <td>{{Created}}</td>
          <td>{{Author.title}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <div class="filtered-count-{{wpId}}">{{items.rows.length}} results</div>
    {{else}}
    <p style="color: #a19f9d; text-align: center; padding: 20px;">
      No items match filter "{{filter.Title}}"
    </p>
    {{/if}}

  {{else}}
    <div class="filtered-placeholder-{{wpId}}">
      <p style="font-size: 16px;">📋</p>
      <p>Select a category from the filter web part to see results.</p>
      <p style="font-size: 12px; color: #c8c6c4;">
        CAML filter uses {{filter.Title}} token — resolved at query time
      </p>
    </div>
  {{/if}}
</div>
