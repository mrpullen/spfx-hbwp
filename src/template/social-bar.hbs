{{!-- 
  Social Bar Template
  ====================
  Replicates the SharePoint modern page social bar with
  Like, Comments, Views, and Save for Later buttons.
  
  CSS classes in <style> blocks are automatically scoped with the
  web part instance ID — no need to add {{wpId}} manually.
  
  Required view fields: Title, LikesCount, FileRef, _CommentCount
  Required expandFields: ["LikedBy"]
  
  Available Data:
  - items: List data with rows from configured view
  - user: Current user profile
  - wpId: Web part instance ID
  - siteUrl: The configured site URL
--}}

<style>
  .social-bar-container {
    font-family: var(--body-font, 'Segoe UI', sans-serif);
    padding: 16px;
  }

  .social-bar-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* --- Social bar row --- */
  .social-bar-wrapper {
    border: 1px solid #edebe9;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.2s ease;
  }

  .social-bar-wrapper:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  /* Item title above the bar */
  .social-bar-title {
    padding: 12px 16px 0;
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: #323130;
  }

  .social-bar-title a {
    color: inherit;
    text-decoration: none;
  }

  .social-bar-title a:hover {
    color: #0078d4;
    text-decoration: underline;
  }

  /* The social bar itself */
  .sp-social-bar {
    display: flex;
    align-items: center;
    padding: 4px 8px;
    min-height: 40px;
    flex-wrap: wrap;
  }

  .sp-social-bar[role="complementary"] {
    gap: 0;
  }

  /* Divider between buttons */
  .social-bar-divider {
    width: 1px;
    height: 20px;
    background-color: #edebe9;
    margin: 0 4px;
    flex-shrink: 0;
  }

  /* Shared button style */
  .social-bar-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: #605e5c;
    font-family: inherit;
    font-size: 14px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .social-bar-btn:hover {
    background: #f3f2f1;
    color: #323130;
  }

  .social-bar-btn:focus-visible {
    outline: 2px solid #0078d4;
    outline-offset: -2px;
    border-radius: 4px;
  }

  .social-bar-btn:active {
    background: #edebe9;
  }

  /* Icon inside button */
  .social-bar-btn .sb-icon {
    font-size: 16px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
  }

  /* Like-specific: liked state */
  .social-bar-btn.sb-liked .sb-icon {
    color: #d13438;
  }

  .social-bar-btn.sb-liked {
    color: #d13438;
  }

  /* Bookmark icon-only button */
  .social-bar-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 8px;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: #605e5c;
    font-size: 16px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .social-bar-btn-icon:hover {
    background: #f3f2f1;
    color: #323130;
  }

  .social-bar-btn-icon:focus-visible {
    outline: 2px solid #0078d4;
    outline-offset: -2px;
    border-radius: 4px;
  }

  /* Empty state */
  .social-bar-empty {
    text-align: center;
    padding: 40px 20px;
    color: #605e5c;
  }
</style>

<div class="social-bar-container">
  {{#if items.rows.length}}
    <div class="social-bar-list">
      {{#each items.rows}}
        <div class="social-bar-wrapper">
          {{!-- Item title --}}
          <h3 class="social-bar-title">
            <a href="{{FileRef}}">{{Title}}</a>
          </h3>

          {{!-- Social bar --}}
          <aside role="complementary"
                 aria-label="Social Bar"
                 class="sp-social-bar">

            {{!-- Like button (interactive) --}}
            {{likeButton ID LikesCount LikedBy ../../user.id}}

            <div class="social-bar-divider"></div>

            {{!-- Comments button --}}
            <a href="{{FileRef}}#comments"
               class="social-bar-btn"
               aria-label="{{_CommentCount}} {{#is _CommentCount "1"}}Comment{{else}}Comments{{/is}}, enter to view comments"
               title="View comments">
              <span class="sb-icon">💬</span>
              <span>{{_CommentCount}} {{#is _CommentCount "1"}}Comment{{else}}Comments{{/is}}</span>
            </a>

            <div class="social-bar-divider"></div>

            {{!-- Views count (read-only display) --}}
            {{#if ViewsLifeTime}}
              <span class="social-bar-btn" style="cursor: default;"
                    aria-label="{{ViewsLifeTime}} Views">
                <span class="sb-icon">👁</span>
                <span>{{ViewsLifeTime}} {{#is ViewsLifeTime "1"}}View{{else}}Views{{/is}}</span>
              </span>
              <div class="social-bar-divider"></div>
            {{/if}}

            {{!-- Save for later / Bookmark --}}
            <a href="{{FileRef}}"
               class="social-bar-btn-icon"
               title="Save this item for later"
               aria-label="Save this item for later">
              🔖
            </a>
            <a href="{{FileRef}}"
               class="social-bar-btn"
               title="Save for later"
               aria-label="Save for later, open page to save">
              <span>Save for later</span>
            </a>

          </aside>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="social-bar-empty">
      <p style="font-size: 16px; font-weight: 600;">No items found</p>
      <p>Items will appear here once they are created.</p>
    </div>
  {{/if}}
</div>
