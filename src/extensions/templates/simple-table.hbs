{{!-- Simple Table Template --}}
<style>
  .hbwp-table { width: 100%; border-collapse: collapse; font-family: 'Segoe UI', system-ui, sans-serif; font-size: 13px; }
  .hbwp-table th { background: #f3f2f1; color: #242424; font-weight: 600; text-align: left; padding: 10px 14px; border-bottom: 2px solid #d2d0ce; white-space: nowrap; }
  .hbwp-table td { padding: 10px 14px; border-bottom: 1px solid #edebe9; color: #323130; }
  .hbwp-table tr:hover td { background: #f5f5f5; }
  .hbwp-table .hbwp-row-even td { background: #fafafa; }
  .hbwp-table .hbwp-row-even:hover td { background: #f0f0f0; }
  .hbwp-table a { color: #0078d4; text-decoration: none; }
  .hbwp-table a:hover { text-decoration: underline; }
  .hbwp-table-empty { padding: 20px; color: #616161; text-align: center; }
  .hbwp-table-footer { font-size: 12px; color: #616161; padding: 8px 0; text-align: right; }
</style>

{{#if items.rows.length}}
<table class="hbwp-table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Modified</th>
      <th>Modified By</th>
    </tr>
  </thead>
  <tbody>
    {{#each items.rows}}
      <tr class="{{#if (mod @index 2)}}hbwp-row-odd{{else}}hbwp-row-even{{/if}}">
        <td>
          {{#if FileRef}}<a href="{{FileRef}}">{{Title}}</a>{{else}}{{Title}}{{/if}}
        </td>
        <td>{{Modified}}</td>
        <td>{{#if Editor}}{{Editor.Title}}{{/if}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>
<div class="hbwp-table-footer">{{items.rows.length}} items</div>
{{else}}
<div class="hbwp-table-empty">No items found.</div>
{{/if}}
